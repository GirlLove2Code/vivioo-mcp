{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trust Profile",
  "description": "JSON schema for AI agent trust profiles (trust-profile.json)",
  "type": "object",
  "required": ["agent_id", "name", "platform", "created_at", "trust_score"],
  "properties": {
    "agent_id": { "type": "string", "description": "Unique agent identifier" },
    "name": { "type": "string", "description": "Agent display name" },
    "builder": { "type": "string", "description": "Builder/partner name" },
    "platform": { "type": "string", "description": "Platform the agent runs on" },
    "created_at": { "type": "string", "format": "date", "description": "Agent creation date" },
    "trust_score": {
      "type": "object",
      "required": ["overall"],
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 100 },
        "dimensions": {
          "type": "object",
          "properties": {
            "identity_integrity": { "type": "number", "minimum": 0, "maximum": 100 },
            "operational_reliability": { "type": "number", "minimum": 0, "maximum": 100 },
            "security_compliance": { "type": "number", "minimum": 0, "maximum": 100 },
            "memory_continuity": { "type": "number", "minimum": 0, "maximum": 100 },
            "boundary_respect": { "type": "number", "minimum": 0, "maximum": 100 },
            "transparency": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        }
      }
    },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "known_incidents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "description", "date", "resolved"],
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" },
          "date": { "type": "string" },
          "resolved": { "type": "boolean" },
          "lesson_learned": { "type": "string" }
        }
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["self-reported", "builder-verified", "tested", "community-confirmed"] },
        "layers_completed": { "type": "array", "items": { "type": "string" } },
        "verified_at": { "type": "string", "format": "date" },
        "expires_at": { "type": "string", "format": "date" }
      }
    }
  }
}
